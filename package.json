{
  "name": "vitest-mock-socket",
  "version": "2.1.0-next.0",
  "description": "Mock and assert websocket interactions with Vitest",
  "keywords": [
    "vitest",
    "websocket",
    "websockets",
    "mock-socket",
    "vitest-mock-socket",
    "test"
  ],
  "author": "andrewangelle@gmail.com",
  "license": "MIT",
  "types": "dist/index.d.mts",
  "module": "dist/index.mjs",
  "repository": "https://github.com/andrewangelle/vitest-mock-socket.git",
  "homepage": "https://github.com/andrewangelle/vitest-mock-socket#readme",
  "bugs": {
    "url": "https://github.com/andrewangelle/vitest-mock-socket/issues",
    "email": "example@npmjs.com"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    }
  },
  "files": [
    "dist",
    "LICENSE.txt",
    "ThirdPartyNotices.txt"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "husky": {
    "hooks": {
      "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
    }
  },
  "lint-staged": {
    "*": [
      "pnpm lint:fix",
      "pnpm format"
    ]
  },
  "scripts": {
    "clean": "rimraf dist",
    "prebuild": "pnpm clean",
    "build": "pnpm clean && pnpm exec tsdown --config ./config/tsdown.config.mts",
    "lint:fix": "pnpm biome check . --write",
    "lint:check": "pnpm biome check .",
    "format": "pnpm biome format . --write",
    "pre-commit": "lint-staged",
    "prepare": "husky",
    "prepublishOnly": "pnpm build",
    "test": "vitest run --config ./config/vitest.config.mts ",
    "test:watch": "vitest watch --config ./config/vitest.config.mts",
    "ci:publish": "pnpm build && npx changeset publish",
    "ci:version": "npx changeset version",
    "commitlint": "commitlint --edit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "@swc/core": "^1.11.9",
    "@swc/types": "^0.1.19",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/expect": "^4.1.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "rimraf": "^6.0.1",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@changesets/cli": "^2.28.0",
    "@vitest/utils": "^3.0.6",
    "mock-socket": "^9.3.1"
  },
  "peerDependencies": {
    "vitest": ">=2"
  },
  "packageManager": "pnpm@11.0.0-rc.5+sha512.c469fb6aa13a99e57aec935cd7b86ff422701f4602ecac2231d3dc20910586ebfb6b50a7b455d0778ec22ae56912d8d8e88e9f9e0a03c0875a6a41783a94a1bd"
}
